-- Frank Samples ported from frank.ml

module Samples where

data Bool = False | True

data Nat = Zero | Succ Nat

plus m n = case m of
    Zero -> n
    Succ k -> Succ (plus k n)

data Tree A = Leaf | Node A (Tree A) (Tree A)

data Empty =

data Unit = tt

-- W-types
data W A B = Sup (x:A) (f:B x -> W A B)

-- Nat as W-type
-- A = Bool, B False = Empty, B True = Unit
data WNat = WNat (W Bool (\b -> case b of False -> Empty; True -> Unit))

zero_w = Sup False (\e -> case e of)
succ_w n = Sup True (\u -> n)

-- to_nat_w w = ... (requires more complex induction handling)

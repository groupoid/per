module test_w where

def A : U := 𝟐
def B (b : 𝟐) : U := ind₂ (λ (_ : 𝟐), U) 𝟎 𝟏 b
def NatW : U := W (b : A), B b

def zeroW : NatW := sup A B 0₂ (λ (e : 𝟎), ind₀ NatW e)
def succW (n : NatW) : NatW := sup A B 1₂ (λ (_ : 𝟏), n)

def wTwo : NatW := succW (succW zeroW)
def wOne : NatW := succW zeroW

def wplus (m n : NatW) : NatW :=
  indᵂ A B (λ (_ : NatW), NatW)
    (λ (b : 𝟐) (f : (B b) → NatW) (rec : (B b) → NatW),
      ind₂ (λ (b : 𝟐), (B b → NatW) → (B b → NatW) → NatW)
        (λ (f1 : 𝟎 → NatW) (rec1 : 𝟎 → NatW), n)
        (λ (f2 : 𝟏 → NatW) (rec2 : 𝟏 → NatW), succW (rec2 ★))
        b f rec)
    m

def test_W : NatW := wplus wTwo wOne
